# Example env — copy to .env and fill in values (never commit .env)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Local scripts only (setup-db, deploy-production, etc.) — never commit real values
SUPABASE_PAT=your_supabase_personal_access_token
SUPABASE_PROJECT_REF=your_project_ref

PROD_URL=https://scorr.walfia.ai
GITHUB_REPO=https://github.com/usmanHassanzai/HR

# Vercel: add only VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in dashboard

# Email (local deploy script only — secrets live on Supabase)
RESEND_API_KEY=
KPI_EMAIL_FROM=Scorr <noreply@scorr.walfia.ai>
